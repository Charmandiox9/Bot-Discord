# Token de tu bot de Discord (Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=tu_token_aqui

# Credenciales de Spotify (Spotify Developer Dashboard -> Create App)
# Solo necesarias si quieres reproducir playlists/canciones de Spotify
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui
