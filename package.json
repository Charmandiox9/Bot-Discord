{
  "name": "Bot Discord",
  "version": "1.0.0",
  "description": "Bot de música para Discord en TypeScript: YouTube, playlists de YouTube y Spotify",
  "main": "dist/index.js",
  "type": "commonjs",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.13",
    "lyrics-finder": "^21.7.0",
    "opusscript": "^0.1.1",
    "spotify-web-api-node": "^5.0.2",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/spotify-web-api-node": "^5.0.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}